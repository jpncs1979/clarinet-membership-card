# 本番用：必ず推測困難な値に変更すること
SESSION_SECRET=change-this-to-a-random-secret-key
PORT=3000
# ローカルで http://localhost を使うときは development（本番ホストでは production を設定）
NODE_ENV=development

# 会員マスタはリポジトリの data/*.csv を git push で更新する運用です。
# 起動時に CSV から JSON へ取り込み、ローカルではファイル保存を監視します。

# data フォルダの CSV 監視を止める場合（例: 本番ホストで fs.watch が不安定なとき）
# WATCH_MEMBERS_CSV=0
